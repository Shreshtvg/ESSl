# ==============================================================================
# Attendix ERP — root .gitignore (Django backend + Vite/React frontend)
# ==============================================================================

# ------------------------------------------------------------------------------
# Secrets & environment
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# ------------------------------------------------------------------------------
# Python / Django (backend/)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
ENV/

# Django
*.log
*.pot
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
/backend/static/

# Packaging / test / coverage
*.egg-info/
.eggs/
build/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# ------------------------------------------------------------------------------
# Node / Vite / React (frontend/)
# ------------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
.vite/
*.local

# Frontend logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------------------------
# Editors / OS
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
